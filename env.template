# Kalshi API
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_ENV=prod
# Optional override for custom endpoints or local testing
# KALSHI_API_BASE_URL=https://api.elections.kalshi.com
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# Trading mode
LIVE_TRADING_ENABLED=false
SHADOW_MODE_ENABLED=false
ENABLE_QUICK_FLIP=false
ENABLE_LIVE_QUICK_FLIP=false
QUICK_FLIP_DISABLE_AI=false
DIRECTIONAL_ALLOCATION=0.45
QUICK_FLIP_ALLOCATION=0.05

# Quick Flip strategy filters
QUICK_FLIP_MAX_MARKET_CHECKS=100
QUICK_FLIP_TARGET_OPPORTUNITY_BUFFER=6
QUICK_FLIP_MIN_ENTRY_PRICE=0.01
QUICK_FLIP_MAX_ENTRY_PRICE=0.20
QUICK_FLIP_MIN_PROFIT_MARGIN=0.10
QUICK_FLIP_CAPITAL_PER_TRADE=50.0
QUICK_FLIP_CONFIDENCE_THRESHOLD=0.60
QUICK_FLIP_MAX_HOLD_MINUTES=30
QUICK_FLIP_MIN_MARKET_VOLUME=1000
QUICK_FLIP_MAX_HOURS_TO_EXPIRY=24
QUICK_FLIP_MAX_BID_ASK_SPREAD=0.02
QUICK_FLIP_MIN_TOP_OF_BOOK_SIZE=10
QUICK_FLIP_MIN_NET_PROFIT=0.10
QUICK_FLIP_MIN_NET_ROI=0.03
QUICK_FLIP_MAX_TARGET_VS_RECENT_TRADE_GAP=0.02
QUICK_FLIP_MIN_RECENT_RANGE_TICKS=2
QUICK_FLIP_MIN_RECENT_PRICE_POSITION=0.40
QUICK_FLIP_MAX_ENTRY_VS_RECENT_LAST_GAP=0.02
QUICK_FLIP_RECENT_TRADE_WINDOW_SECONDS=3600
QUICK_FLIP_MIN_RECENT_TRADE_COUNT=8

# Probability engine and fee-aware EV gating. The live-trade loop blends the
# model's fair probability with the market price (MARKET_BLEND_MODEL_WEIGHT on
# the model side), shrinks it by realized settlement calibration when enabled,
# and requires at least LIVE_TRADE_MIN_NET_EDGE dollars of edge per contract
# after estimated Kalshi fees before any BUY intent is executed.
LIVE_TRADE_MIN_NET_EDGE=0.02
LIVE_TRADE_MIN_CONFIDENCE=0.55
ENSEMBLE_EXTREMIZE_FACTOR=1.2
MARKET_BLEND_MODEL_WEIGHT=0.65
CALIBRATION_SHRINK_ENABLED=true
# Microstructure guards on the live-trade EV gate: refuse entries when the
# bid-ask spread exceeds the cap or the top of book is thinner than the
# minimum (0 disables either guard).
LIVE_TRADE_MAX_SPREAD_CENTS=6
LIVE_TRADE_MIN_TOP_DEPTH_CONTRACTS=10
# Category exploration: unproven categories (<5 settled trades) get a small
# exploration score (2% allocation tier) instead of a hard block so they can
# build a track record. Paper/shadow explore by default; live requires the
# extra CATEGORY_EXPLORATION_LIVE opt-in.
CATEGORY_EXPLORATION_ENABLED=true
CATEGORY_EXPLORATION_LIVE=false
CATEGORY_EXPLORATION_SCORE=35
# Optional comma-separated RSS feed override for the news/sentiment pipeline.
# RSS_FEEDS=https://rss.nytimes.com/services/xml/rss/nyt/Business.xml,https://feeds.bbci.co.uk/news/business/rss.xml

# Execution safety guards inspired by API-bot failure reports. Enabled by
# default; set EXECUTION_SAFETY_ENABLED=false only for controlled tests.
EXECUTION_SAFETY_ENABLED=true
EXECUTION_SAFETY_STALE_BOOK_SECONDS=90
EXECUTION_SAFETY_MAX_QUOTE_MOVE_CENTS=12
EXECUTION_SAFETY_SIBLING_SPIKE_THRESHOLD=0.95
EXECUTION_SAFETY_MIN_SIBLING_SPIKES=3
# Block trades whenever the most recent kalshi.public-api source-health
# snapshot is older than this many seconds, or shows an error/unavailable
# status. Disable with EXECUTION_SAFETY_REQUIRE_EXCHANGE_HEALTH=false.
EXECUTION_SAFETY_EXCHANGE_STALE_SECONDS=120
EXECUTION_SAFETY_REQUIRE_EXCHANGE_HEALTH=true
# Optional per-strategy policy overrides. Format is a JSON object whose keys
# match SafetyPolicy fields, for example:
#   EXECUTION_SAFETY_STRATEGY_POLICY_QUICK_FLIP_SCALPING={"max_quote_move_cents":4,"stale_book_seconds":30}
# EXECUTION_SAFETY_STRATEGY_POLICY_LIVE_TRADE=
# EXECUTION_SAFETY_STRATEGY_POLICY_QUICK_FLIP_SCALPING=

# Local operator API (`python cli.py mcp`). Live order calls are disabled unless
# this explicit opt-in is set. Set OPERATOR_API_TOKEN to a long random string
# if you need to expose the API to non-loopback callers; without a token, the
# API rejects everything that is not 127.0.0.1/::1.
OPERATOR_API_ALLOW_LIVE_ORDERS=false
OPERATOR_API_TOKEN=

# Dashboard API mutation protection. Local socket-peer loopback writes
# (127.0.0.0/8, ::1, or IPv4-mapped 127.0.0.0/8) work without this token.
# Set a long random value before exposing
# DASHBOARD_SERVER_HOST beyond 127.0.0.1; non-loopback writes must then send
# `Authorization: Bearer <token>` or `x-dashboard-token: <token>`.
# The Next.js UI proxies browser mutations via /api/proxy and injects this
# token server-side (do not put it in NEXT_PUBLIC_*).
DASHBOARD_API_TOKEN=

POLYMARKET_MARKETS_URL=https://gamma-api.polymarket.com/markets
QUICK_FLIP_MAKER_ENTRY_TIMEOUT_SECONDS=180
QUICK_FLIP_MAKER_ENTRY_POLL_SECONDS=5
QUICK_FLIP_MAKER_ENTRY_REPRICE_SECONDS=30
QUICK_FLIP_DYNAMIC_EXIT_REPRICE_SECONDS=60
QUICK_FLIP_STOP_LOSS_PCT=0.08

# Per-strategy guardrails
QUICK_FLIP_DAILY_LOSS_BUDGET_PCT=0.05
# Strategy concurrency cap controls how many Quick Flip opportunities can be selected/in flight at once
QUICK_FLIP_MAX_CONCURRENT_POSITIONS=10
# Portfolio open-position cap controls how many positions may stay open simultaneously
QUICK_FLIP_MAX_OPEN_POSITIONS=5
QUICK_FLIP_MAX_TRADES_PER_HOUR=20
LIVE_TRADE_DAILY_LOSS_BUDGET_PCT=0.05
LIVE_TRADE_MAX_OPEN_POSITIONS=5
LIVE_TRADE_MAX_TRADES_PER_HOUR=20

# Shadow drift auto-pause. When enabled, paper-vs-live shadow
# order divergence is monitored and the strategy is automatically halted if
# average per-entry price drift (in cents) or total entry-cost drift (in USD)
# exceeds the configured thresholds. Default off — observability only unless
# you opt in. `SHADOW_DRIFT_MIN_MATCHED_ENTRIES` is a noise floor: drift is
# evaluated only after at least this many shadow buys have matched a position.
SHADOW_DRIFT_AUTO_PAUSE_ENABLED=false
SHADOW_DRIFT_MAX_AVG_ABS_ENTRY_DELTA_CENTS=2.0
SHADOW_DRIFT_MAX_TOTAL_ENTRY_COST_DELTA_USD=25.0
SHADOW_DRIFT_MIN_MATCHED_ENTRIES=5

# Push-based dashboard refresh hook. When the Python live-trade loop
# writes a decision / runtime-state / feedback row it can fire-and-forget a
# POST to LIVE_TRADE_NOTIFY_URL with the shared secret token below in the
# x-internal-token header to push an immediate SSE refresh. Leave both blank
# to fall back to the slower cursor-polling refresh path (no behavior change).
LIVE_TRADE_NOTIFY_URL=
LIVE_TRADE_INTERNAL_REFRESH_TOKEN=

# Weather forecast model (Open-Meteo ensemble + NWS, all free / no API key).
# The deterministic bucket model computes P(temperature/precip bucket) from
# ensemble member forecasts, recentered toward the official NWS point
# forecast, conditioned on the observed running max for same-day contracts,
# and pools that probability with the LLM estimate before the EV gate.
WEATHER_TRADING_ENABLED=true
# Open-Meteo ensemble models to pool (gfs_seamless=31 members, ecmwf_ifs025=51)
WEATHER_ENSEMBLE_MODELS=gfs_seamless,ecmwf_ifs025
# Weight of the deterministic model vs the LLM when pooling fair probability
# (scaled by estimate quality; 0 disables the deterministic override)
WEATHER_MODEL_POOL_WEIGHT=0.75
# Never enter weather positions further out than this many days
WEATHER_MAX_LEAD_DAYS=6
# Kernel bandwidth model (deg F): sigma = max(floor, base + per_day * lead)
WEATHER_SIGMA_FLOOR_F=1.2
WEATHER_SIGMA_BASE_F=1.6
WEATHER_SIGMA_PER_DAY_F=0.5
WEATHER_UNVERIFIED_EXTRA_SIGMA_F=1.5
# Kernel bandwidth for precipitation totals (inches)
WEATHER_RAIN_SIGMA_IN=0.08
WEATHER_SNOW_SIGMA_IN=0.3
# Ensemble recentering toward the NWS point forecast (settlement source)
WEATHER_NWS_BLEND_WEIGHT=0.35
# Margin (deg F) the observed running extreme must clear a boundary before
# the model emits a hard 0/1 on same-day contracts
WEATHER_RUNNING_OBS_MARGIN_F=1.5
WEATHER_CLIMATOLOGY_YEARS=10
WEATHER_MIN_ENSEMBLE_MEMBERS=8
# Estimates below this quality score are never pooled into the EV gate
WEATHER_MIN_QUALITY_TO_POOL=0.35
WEATHER_ALLOW_GEOCODE_FALLBACK=true
WEATHER_REQUEST_TIMEOUT_SECONDS=8.0

# Sportsbook odds gate anchor (ESPN moneylines, free / no API key). De-vigged
# home/away win probabilities are pooled into the live-trade EV gate for
# game-winner markets the same way weather forecasts are — the sharpest public
# prior in the bot's only proven niche (NCAAB). Conservative weight by default
# since Kalshi title->team mapping is fuzzier than the weather per-ticker map.
SPORTS_ODDS_GATE_ENABLED=true
# Weight of the sportsbook probability vs the LLM (scaled by estimate quality)
SPORTS_MODEL_POOL_WEIGHT=0.55
# Estimates below this quality score are never pooled into the EV gate
SPORTS_MIN_QUALITY_TO_POOL=0.5
# In-game quality ceiling. ESPN scoreboard moneylines are a pre-game line that
# goes stale once the game tips off, so 0 = never pool in-game (fail-closed).
SPORTS_IN_GAME_MAX_QUALITY=0.0

# News relevance recency half-life (hours). Article ranking = keyword overlap
# x exp(-age/half_life) so breaking catalysts (injuries, line moves) outrank
# stale matches; a very large value disables the decay.
NEWS_HALF_LIFE_HOURS=36.0

# Per-event portfolio concentration cap (fraction of portfolio). Caps exposure
# sharing one Kalshi event/series root so an upset-heavy slate cannot cluster
# correlated losses through one event. 1.0 disables it (sector cap still applies).
MAX_EVENT_CONCENTRATION_PCT=0.12

# Total-portfolio usage cap (dry-powder floor). 1.0 = full deployment allowed.
# Set e.g. 0.90 to keep ~10% cash free for the next high-edge opportunity.
MAX_PORTFOLIO_USAGE_PCT=1.0

# Cross-market (Polymarket) price pooled into the live-trade EV gate as a second
# external prior. OPT-IN (default off): the LLM already sees the price as prose
# and the text->ticker mapping can be imprecise. When on, fresh+liquid+high-
# confidence matches are log-odds-pooled at a small confidence-scaled weight.
CROSS_MARKET_POOL_ENABLED=false
CROSS_MARKET_MIN_MAPPING_CONFIDENCE=0.65
CROSS_MARKET_MIN_VOLUME_USD=2000
CROSS_MARKET_POOL_WEIGHT_BASE=0.20
CROSS_MARKET_POOL_WEIGHT_CAP=0.25
CROSS_MARKET_MAX_AGE_SECONDS=900

# Route decide.py's main BUY path through the canonical evaluate_trade_intent
# gate (same as the live-trade loop) instead of the legacy EdgeFilter gate.
# OPT-IN (default off): decision-core behavior change — shadow/backtest first.
DECIDE_USE_CANONICAL_GATE=false

# Half-life (days) for exponential recency weighting of per-role skill Brier
# scores, so a stale model/regime stops up-weighting a role. Large = legacy
# unweighted lifetime average.
MODEL_SKILL_BRIER_HALFLIFE_DAYS=90
# Weather scan job (python cli.py weather-scan, plus a 30-minute background
# sweep inside `python cli.py run` when WEATHER_SCAN_TRADE_ENABLED is true).
# Sweeps every open weather event with the deterministic model — no LLM cost —
# and executes fee-positive divergences through the EV gate and guardrails.
# Live execution additionally requires LIVE_TRADING_ENABLED + WEATHER_SCAN_LIVE.
# WEATHER_SCAN_SERIES=KXHIGHNY,KXHIGHCHI   # empty = all registry stations
WEATHER_SCAN_MIN_NET_EDGE=0.03
WEATHER_SCAN_MIN_QUALITY=0.5
WEATHER_SCAN_MAX_EVENTS=16
WEATHER_SCAN_MAX_POSITIONS=5
WEATHER_SCAN_TRADE_ENABLED=true
WEATHER_SCAN_LIVE=false

# Market focus
# Comma-separated Kalshi categories, e.g. Sports, Politics, Economics
PREFERRED_CATEGORIES=Sports
EXCLUDED_CATEGORIES=
PREFER_LIVE_WAGERING=true
LIVE_WAGERING_MAX_HOURS_TO_EXPIRY=12

# LLM provider selection
# - auto (default): prefers the Codex CLI (ChatGPT plan quota) when `codex` is
#   on PATH and signed in, then direct OpenAI (if OPENAI_API_KEY is set), and
#   finally falls back to OpenRouter.
# - codex: force the Codex CLI subprocess (requires `codex login`).
# - openai: direct OpenAI API (billed to OPENAI_API_KEY).
# - openrouter: unified OpenRouter routing (billed to OPENROUTER_API_KEY).
LLM_PROVIDER=auto

# Codex CLI (ChatGPT plan quota, no OpenAI API billing).
# Leave CODEX_CLI_PATH blank to auto-detect via PATH. Set CODEX_PLAN_TIER to
# your plan for future quota telemetry (free / plus / pro / team / business).
CODEX_CLI_PATH=
CODEX_PLAN_TIER=plus

# Direct OpenAI API access
OPENAI_API_KEY=

# OpenRouter access
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional attribution headers for OpenRouter rankings / app discovery
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=Kalshi AI Trading Bot

# Optional cost controls
DAILY_AI_COST_LIMIT=10.0

# --- Statistical decision reinforcement (2026-06) ---
# ML outcome meta-model trained on settled trades (numpy logistic regression,
# random forest when scikit-learn is installed and >=400 settlements exist).
ML_META_MODEL_ENABLED=true
ML_META_MODEL_MAX_BLEND_WEIGHT=0.35
# Hold near-certain winners to fee-free settlement instead of selling early.
HOLD_WINNERS_TO_SETTLEMENT=true
HOLD_WINNERS_TO_SETTLEMENT_PRICE=0.95
# Quick-flip momentum confirmation: supporting depth must be at least this
# fraction of opposing top-of-book depth (0 disables).
QUICK_FLIP_MIN_BID_ASK_SIZE_RATIO=0.5

# --- Market-prior calibration + model skill weighting (2026-06) ---
# Settlement-result backfill: hourly batched Kalshi lookups label expired
# snapshotted markets (market_outcomes + market_snapshots.market_result),
# building the training set the market-prior calibration learns from.
RESULT_BACKFILL_ENABLED=true
RESULT_BACKFILL_INTERVAL_MINUTES=60
RESULT_BACKFILL_MAX_TICKERS_PER_RUN=400
# Per-TTE-segment Platt calibration of the market mid (fit via
# `python cli.py fit-market-prior`); fails closed to the raw mid until a
# segment beats it on holdout Brier.
MARKET_PRIOR_CALIBRATION_ENABLED=true
# Scale ensemble pooling weights by each role's realized per-category Brier
# skill (shrunk toward the role's global multiplier, then 1.0).
MODEL_SKILL_WEIGHTING_ENABLED=true
# Quick-flip statistical gates: movement confidence must clear the
# candidate's break-even win probability (fees + stop risk vs net reward),
# and candidates with no public trade newer than this many seconds are
# rejected before any AI spend (0 disables).
QUICK_FLIP_EV_GATE_ENABLED=true
QUICK_FLIP_EV_CONFIDENCE_MARGIN=0.0
QUICK_FLIP_MAX_LAST_TRADE_AGE_SECONDS=900
# Cap standard live-trade position size at the fractional-Kelly bankroll
# fraction implied by the gate's blended win probability (mode-blind).
LIVE_TRADE_KELLY_SIZING_ENABLED=true
LIVE_TRADE_KELLY_MULTIPLIER=0.25
