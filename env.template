# Kalshi API
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_ENV=prod
# Optional override for custom endpoints or local testing
# KALSHI_API_BASE_URL=https://api.elections.kalshi.com
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# Trading mode
LIVE_TRADING_ENABLED=false
SHADOW_MODE_ENABLED=false
ENABLE_QUICK_FLIP=false
ENABLE_LIVE_QUICK_FLIP=false
QUICK_FLIP_DISABLE_AI=false
DIRECTIONAL_ALLOCATION=0.45
QUICK_FLIP_ALLOCATION=0.05

# Quick Flip strategy filters
QUICK_FLIP_MAX_MARKET_CHECKS=100
QUICK_FLIP_TARGET_OPPORTUNITY_BUFFER=6
QUICK_FLIP_MIN_ENTRY_PRICE=0.01
QUICK_FLIP_MAX_ENTRY_PRICE=0.20
QUICK_FLIP_MIN_PROFIT_MARGIN=0.10
QUICK_FLIP_CAPITAL_PER_TRADE=50.0
QUICK_FLIP_CONFIDENCE_THRESHOLD=0.60
QUICK_FLIP_MAX_HOLD_MINUTES=30
QUICK_FLIP_MIN_MARKET_VOLUME=1000
QUICK_FLIP_MAX_HOURS_TO_EXPIRY=24
QUICK_FLIP_MAX_BID_ASK_SPREAD=0.02
QUICK_FLIP_MIN_TOP_OF_BOOK_SIZE=10
QUICK_FLIP_MIN_NET_PROFIT=0.10
QUICK_FLIP_MIN_NET_ROI=0.03
QUICK_FLIP_MAX_TARGET_VS_RECENT_TRADE_GAP=0.02
QUICK_FLIP_MIN_RECENT_RANGE_TICKS=2
QUICK_FLIP_MIN_RECENT_PRICE_POSITION=0.40
QUICK_FLIP_MAX_ENTRY_VS_RECENT_LAST_GAP=0.02
QUICK_FLIP_RECENT_TRADE_WINDOW_SECONDS=3600
QUICK_FLIP_MIN_RECENT_TRADE_COUNT=8

# Execution safety guards inspired by API-bot failure reports. Enabled by
# default; set EXECUTION_SAFETY_ENABLED=false only for controlled tests.
EXECUTION_SAFETY_ENABLED=true
EXECUTION_SAFETY_STALE_BOOK_SECONDS=90
EXECUTION_SAFETY_MAX_QUOTE_MOVE_CENTS=12
EXECUTION_SAFETY_SIBLING_SPIKE_THRESHOLD=0.95
EXECUTION_SAFETY_MIN_SIBLING_SPIKES=3
# Block trades whenever the most recent kalshi.public-api source-health
# snapshot is older than this many seconds, or shows an error/unavailable
# status. Disable with EXECUTION_SAFETY_REQUIRE_EXCHANGE_HEALTH=false.
EXECUTION_SAFETY_EXCHANGE_STALE_SECONDS=120
EXECUTION_SAFETY_REQUIRE_EXCHANGE_HEALTH=true
# Optional per-strategy policy overrides. Format is a JSON object whose keys
# match SafetyPolicy fields, for example:
#   EXECUTION_SAFETY_STRATEGY_POLICY_QUICK_FLIP_SCALPING={"max_quote_move_cents":4,"stale_book_seconds":30}
# EXECUTION_SAFETY_STRATEGY_POLICY_LIVE_TRADE=
# EXECUTION_SAFETY_STRATEGY_POLICY_QUICK_FLIP_SCALPING=

# Local operator API (`python cli.py mcp`). Live order calls are disabled unless
# this explicit opt-in is set. Set OPERATOR_API_TOKEN to a long random string
# if you need to expose the API to non-loopback callers; without a token, the
# API rejects everything that is not 127.0.0.1/::1.
OPERATOR_API_ALLOW_LIVE_ORDERS=false
OPERATOR_API_TOKEN=
POLYMARKET_MARKETS_URL=https://gamma-api.polymarket.com/markets
QUICK_FLIP_MAKER_ENTRY_TIMEOUT_SECONDS=180
QUICK_FLIP_MAKER_ENTRY_POLL_SECONDS=5
QUICK_FLIP_MAKER_ENTRY_REPRICE_SECONDS=30
QUICK_FLIP_DYNAMIC_EXIT_REPRICE_SECONDS=60
QUICK_FLIP_STOP_LOSS_PCT=0.08

# Per-strategy guardrails
QUICK_FLIP_DAILY_LOSS_BUDGET_PCT=0.05
# Strategy concurrency cap controls how many Quick Flip opportunities can be selected/in flight at once
QUICK_FLIP_MAX_CONCURRENT_POSITIONS=10
# Portfolio open-position cap controls how many positions may stay open simultaneously
QUICK_FLIP_MAX_OPEN_POSITIONS=5
QUICK_FLIP_MAX_TRADES_PER_HOUR=20
LIVE_TRADE_DAILY_LOSS_BUDGET_PCT=0.05
LIVE_TRADE_MAX_OPEN_POSITIONS=5
LIVE_TRADE_MAX_TRADES_PER_HOUR=20

# Shadow drift auto-pause. When enabled, paper-vs-live shadow
# order divergence is monitored and the strategy is automatically halted if
# average per-entry price drift (in cents) or total entry-cost drift (in USD)
# exceeds the configured thresholds. Default off — observability only unless
# you opt in. `SHADOW_DRIFT_MIN_MATCHED_ENTRIES` is a noise floor: drift is
# evaluated only after at least this many shadow buys have matched a position.
SHADOW_DRIFT_AUTO_PAUSE_ENABLED=false
SHADOW_DRIFT_MAX_AVG_ABS_ENTRY_DELTA_CENTS=2.0
SHADOW_DRIFT_MAX_TOTAL_ENTRY_COST_DELTA_USD=25.0
SHADOW_DRIFT_MIN_MATCHED_ENTRIES=5

# Push-based dashboard refresh hook. When the Python live-trade loop
# writes a decision / runtime-state / feedback row it can fire-and-forget a
# POST to LIVE_TRADE_NOTIFY_URL with the shared secret token below in the
# x-internal-token header to push an immediate SSE refresh. Leave both blank
# to fall back to the slower cursor-polling refresh path (no behavior change).
LIVE_TRADE_NOTIFY_URL=
LIVE_TRADE_INTERNAL_REFRESH_TOKEN=

# Market focus
# Comma-separated Kalshi categories, e.g. Sports, Politics, Economics
PREFERRED_CATEGORIES=Sports
EXCLUDED_CATEGORIES=
PREFER_LIVE_WAGERING=true
LIVE_WAGERING_MAX_HOURS_TO_EXPIRY=12

# LLM provider selection
# - auto (default): prefers the Codex CLI (ChatGPT plan quota) when `codex` is
#   on PATH and signed in, then direct OpenAI (if OPENAI_API_KEY is set), and
#   finally falls back to OpenRouter.
# - codex: force the Codex CLI subprocess (requires `codex login`).
# - openai: direct OpenAI API (billed to OPENAI_API_KEY).
# - openrouter: unified OpenRouter routing (billed to OPENROUTER_API_KEY).
LLM_PROVIDER=auto

# Codex CLI (ChatGPT plan quota, no OpenAI API billing).
# Leave CODEX_CLI_PATH blank to auto-detect via PATH. Set CODEX_PLAN_TIER to
# your plan for future quota telemetry (free / plus / pro / team / business).
CODEX_CLI_PATH=
CODEX_PLAN_TIER=plus

# Direct OpenAI API access
OPENAI_API_KEY=

# OpenRouter access
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional attribution headers for OpenRouter rankings / app discovery
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=Kalshi AI Trading Bot

# Optional cost controls
DAILY_AI_COST_LIMIT=10.0
