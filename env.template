# Kalshi API
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_ENV=prod
# Optional override for custom endpoints or local testing
# KALSHI_API_BASE_URL=https://api.elections.kalshi.com
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# Trading mode
LIVE_TRADING_ENABLED=false
ENABLE_QUICK_FLIP=false
ENABLE_LIVE_QUICK_FLIP=false

# Market focus
# Comma-separated Kalshi categories, e.g. Sports, Politics, Economics
PREFERRED_CATEGORIES=Sports
EXCLUDED_CATEGORIES=
PREFER_LIVE_WAGERING=true
LIVE_WAGERING_MAX_HOURS_TO_EXPIRY=12

# LLM provider selection
# auto prefers direct OpenAI access when OPENAI_API_KEY is set, otherwise OpenRouter
LLM_PROVIDER=auto

# Direct OpenAI API access
OPENAI_API_KEY=

# OpenRouter access
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional attribution headers for OpenRouter rankings / app discovery
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=Kalshi AI Trading Bot

# Optional cost controls
DAILY_AI_COST_LIMIT=10.0
