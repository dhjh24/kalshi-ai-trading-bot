# Kalshi API
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_ENV=prod
# Optional override for custom endpoints or local testing
# KALSHI_API_BASE_URL=https://api.elections.kalshi.com
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# Trading mode
LIVE_TRADING_ENABLED=false
ENABLE_QUICK_FLIP=false
ENABLE_LIVE_QUICK_FLIP=false

# Market focus
# Comma-separated Kalshi categories, e.g. Sports, Politics, Economics
PREFERRED_CATEGORIES=Sports
EXCLUDED_CATEGORIES=
PREFER_LIVE_WAGERING=true
LIVE_WAGERING_MAX_HOURS_TO_EXPIRY=12

# LLM provider selection
# - auto (default): prefers the Codex CLI (ChatGPT plan quota) when `codex` is
#   on PATH and signed in, then direct OpenAI (if OPENAI_API_KEY is set), and
#   finally falls back to OpenRouter.
# - codex: force the Codex CLI subprocess (requires `codex login`).
# - openai: direct OpenAI API (billed to OPENAI_API_KEY).
# - openrouter: unified OpenRouter routing (billed to OPENROUTER_API_KEY).
LLM_PROVIDER=auto

# Codex CLI (ChatGPT plan quota, no OpenAI API billing).
# Leave CODEX_CLI_PATH blank to auto-detect via PATH. Set CODEX_PLAN_TIER to
# your plan for future quota telemetry (free / plus / pro / team / business).
CODEX_CLI_PATH=
CODEX_PLAN_TIER=plus

# Direct OpenAI API access
OPENAI_API_KEY=

# OpenRouter access
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional attribution headers for OpenRouter rankings / app discovery
OPENROUTER_HTTP_REFERER=
OPENROUTER_TITLE=Kalshi AI Trading Bot

# Optional cost controls
DAILY_AI_COST_LIMIT=10.0
